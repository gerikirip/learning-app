# Local Docker Compose (copy to .env in repo root)

POSTGRES_DB=learningdb
POSTGRES_USER=learning
POSTGRES_PASSWORD=learning
DATABASE_URL=postgresql+psycopg://learning:learning@db:5432/learningdb

# Dev frontend only — prod/Railway uses nginx proxy (empty = same origin)
VITE_API_BASE_URL=http://localhost:8000

# --- Railway: set variables on the correct service only ---

# Backend service:
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Frontend service (replace "backend" with your backend service name):
# BACKEND_URL=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:${{backend.PORT}}
